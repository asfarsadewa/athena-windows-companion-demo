<Window x:Class="AthenaCompanion.Settings.OnboardingWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Athena"
        Width="480"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#17151f">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="18,16,18,10"
                   LastChildFill="True">
            <TextBlock x:Name="StepText"
                       DockPanel.Dock="Right"
                       Foreground="#bdb4d4"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Text="1 of 4" />
            <StackPanel>
                <TextBlock Text="Athena Companion"
                           Foreground="#f7f1ff"
                           FontSize="19"
                           FontWeight="SemiBold" />
                <TextBlock Text="First-run setup"
                           Foreground="#bdb4d4"
                           FontSize="12" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Margin="18,0"
                Padding="18"
                Background="#201d2b"
                BorderBrush="#3f3855"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText"
                           Foreground="#f7f1ff"
                           FontSize="17"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="BodyText"
                           Grid.Row="1"
                           Margin="0,12,0,0"
                           Foreground="#ded8ed"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Button x:Name="SetUpKeyButton"
                            Content="Set up key..."
                            MinWidth="104"
                            Height="30"
                            Margin="0,14,8,0"
                            Click="OnSetUpKey" />
                    <Button x:Name="OpenMusicFolderButton"
                            Content="Open music folder"
                            MinWidth="130"
                            Height="30"
                            Margin="0,14,8,0"
                            Click="OnOpenMusicFolder" />
                    <TextBlock x:Name="ActionStatusText"
                               VerticalAlignment="Center"
                               Margin="2,14,0,0"
                               Foreground="#bdb4d4"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2"
                   Margin="18,12,18,16"
                   LastChildFill="False">
            <Button Content="Skip"
                    Width="76"
                    Height="30"
                    Click="OnSkip" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="BackButton"
                        Content="Back"
                        Width="76"
                        Height="30"
                        Margin="0,0,8,0"
                        Click="OnBack" />
                <Button x:Name="NextButton"
                        Content="Next"
                        Width="76"
                        Height="30"
                        IsDefault="True"
                        Click="OnNext" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
