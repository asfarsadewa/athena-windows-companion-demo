<Window x:Class="AthenaCompanion.UI.MusicPlayerWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Athena Radio"
        Width="420"
        Height="360"
        MinWidth="360"
        MinHeight="300"
        ResizeMode="CanResize"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Grid Background="#151419">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="14,12,14,6"
                   LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Content="Close"
                    Width="72"
                    Height="28"
                    Click="OnClose" />
            <StackPanel>
                <TextBlock Text="Athena Radio"
                           Foreground="#f7f1ff"
                           FontSize="17"
                           FontWeight="SemiBold" />
                <TextBlock Text="AM/SW mono"
                           Foreground="#bdb4d4"
                           FontSize="12" />
            </StackPanel>
        </DockPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Margin="14,0,14,8"
                   Foreground="#d8d0ea"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis" />

        <Grid Grid.Row="2"
              Margin="14,0">
            <Border Background="#201d2b"
                    BorderBrush="#3f3855"
                    BorderThickness="1"
                    CornerRadius="8">
                <ListBox x:Name="TracksList"
                         Margin="0"
                         Padding="4"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#f7f1ff"
                         DisplayMemberPath="RelativePath"
                         SelectionChanged="OnTrackSelectionChanged"
                         MouseDoubleClick="OnTrackDoubleClick" />
            </Border>

            <StackPanel x:Name="EmptyState"
                        Margin="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="No music found"
                           HorizontalAlignment="Center"
                           Foreground="#f7f1ff"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="EmptyStateText"
                           Width="320"
                           Margin="0,8,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="#bdb4d4"
                           FontSize="12" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3"
              Margin="14,10,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PositionText"
                       Width="42"
                       VerticalAlignment="Center"
                       Foreground="#bdb4d4"
                       Text="0:00" />
            <Slider x:Name="SeekSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    ValueChanged="OnSeekSliderValueChanged"
                    PreviewMouseLeftButtonDown="OnSeekStarted"
                    PreviewMouseLeftButtonUp="OnSeekCompleted" />
            <TextBlock x:Name="DurationText"
                       Grid.Column="2"
                       Width="42"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Foreground="#bdb4d4"
                       Text="0:00" />
        </Grid>

        <DockPanel Grid.Row="4"
                   Margin="14,10,14,14"
                   LastChildFill="False">
            <Button Content="Open folder"
                    MinWidth="90"
                    Height="30"
                    Click="OnOpenFolder" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Content="&lt;&lt;"
                        Width="42"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="OnPrevious" />
                <Button x:Name="PlayPauseButton"
                        Content="Play"
                        Width="58"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="OnPlayPause" />
                <Button Content="&gt;&gt;"
                        Width="42"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="OnNext" />
                <Button Content="Stop"
                        Width="52"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="OnStop" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
