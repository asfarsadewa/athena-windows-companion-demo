<Window x:Class="AthenaCompanion.UI.DogWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Athena Puppy"
        Width="130"
        Height="116"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        Loaded="OnLoaded">
    <Grid Background="Transparent"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <Border x:Name="BarkBubble"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,2,0,0"
                Padding="8,3"
                Background="#E82B2430"
                BorderBrush="#D8FFF0B8"
                BorderThickness="1"
                CornerRadius="9"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="BarkBubbleText"
                       Foreground="#FFFFF7DD"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Text="woof" />
        </Border>

        <Image x:Name="DogSpriteImage"
               Width="94"
               Height="82"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.5,0.5"
               Stretch="Uniform" />
    </Grid>
</Window>
