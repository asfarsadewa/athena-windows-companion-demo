<Window x:Class="AthenaCompanion.UI.ImageLightboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Athena Image"
        Width="900"
        Height="680"
        MinWidth="520"
        MinHeight="420"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#17151f">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="16"
                Background="#201d2b"
                BorderBrush="#3f3855"
                BorderThickness="1"
                CornerRadius="8">
            <Image x:Name="GeneratedImage"
                   Margin="12"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>

        <DockPanel Grid.Row="1"
                   LastChildFill="False"
                   Margin="16,0,16,16">
            <TextBlock x:Name="PathText"
                       DockPanel.Dock="Left"
                       Foreground="#c7c0d9"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="560" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Content="Copy"
                        Width="84"
                        Margin="0,0,8,0"
                        Click="OnCopy" />
                <Button Content="Open Folder"
                        Width="104"
                        Margin="0,0,8,0"
                        Click="OnOpenFolder" />
                <Button Content="Close"
                        Width="84"
                        Click="OnClose" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
