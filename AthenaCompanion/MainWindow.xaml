<Window x:Class="AthenaCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athena Companion"
        Width="190"
        Height="176"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        Loaded="OnLoaded"
        Closed="OnClosed"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseRightButtonUp="OnMouseRightButtonUp">
    <Grid x:Name="Root"
          Background="Transparent"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <Border x:Name="TextModeBubble"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,6,6,0"
                Padding="10,5"
                Background="#E8262233"
                BorderBrush="#B8D9CCFF"
                BorderThickness="1"
                CornerRadius="10"
                MouseLeftButtonUp="OnTextModeBubbleMouseLeftButtonUp">
            <TextBlock Text="Chat"
                       Foreground="#F7F1FF"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>

        <Border x:Name="VoiceBusyIndicator"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,4,0,0"
                Padding="8,3"
                Background="#E8201D2B"
                BorderBrush="#A8D9CCFF"
                BorderThickness="1"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="VoiceBusyText"
                           Foreground="#F7F1FF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="Thinking" />
                <TextBlock x:Name="VoiceBusyDots"
                           Width="16"
                           Foreground="#F7F1FF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="..." />
            </StackPanel>
        </Border>

        <Image x:Name="SpriteImage"
               Width="160"
               Height="144"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.5,0.5"
               Stretch="Uniform" />
    </Grid>
</Window>
