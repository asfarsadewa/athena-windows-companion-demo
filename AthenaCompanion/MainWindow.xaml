<Window x:Class="AthenaCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Athena Companion"
        Width="190"
        Height="176"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        Loaded="OnLoaded"
        Closed="OnClosed"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        MouseRightButtonUp="OnMouseRightButtonUp">
    <Grid x:Name="Root"
          Background="Transparent"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <Border x:Name="TextModeBubble"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="2"
                Margin="0,10,55,0"
                Padding="10,5"
                Background="#E8262233"
                BorderBrush="#B8D9CCFF"
                BorderThickness="1"
                CornerRadius="10"
                Cursor="Hand"
                ToolTip="Open text chat"
                MouseLeftButtonUp="OnTextModeBubbleMouseLeftButtonUp">
            <TextBlock x:Name="TextModeBubbleText"
                       Text="Hmm ..."
                       Foreground="#F7F1FF"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>

        <Border x:Name="VoiceModeBubble"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="2"
                Margin="18,24,0,0"
                Padding="8,5"
                Background="#E8262233"
                BorderBrush="#B8D9CCFF"
                BorderThickness="1"
                CornerRadius="10"
                Cursor="Hand"
                ToolTip="Enter voice chat"
                MouseLeftButtonUp="OnVoiceModeBubbleMouseLeftButtonUp">
            <Viewbox Width="14"
                     Height="14"
                     Stretch="Uniform">
                <Canvas Width="24"
                        Height="24">
                    <Path Data="M12,14 C10.343,14 9,12.657 9,11 L9,5 C9,3.343 10.343,2 12,2 C13.657,2 15,3.343 15,5 L15,11 C15,12.657 13.657,14 12,14 Z M19,10 L19,11 C19,14.866 15.866,18 12,18 C8.134,18 5,14.866 5,11 L5,10 M12,18 L12,22 M8,22 L16,22"
                          Stroke="#F7F1FF"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent" />
                </Canvas>
            </Viewbox>
        </Border>

        <Button x:Name="PuppyButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="2"
                Margin="0,23,18,0"
                Width="31"
                Height="31"
                Padding="4"
                Background="#D8241F2F"
                BorderBrush="#B8FFF0B8"
                BorderThickness="1"
                Cursor="Hand"
                ToolTip="Spawn puppy"
                Click="OnPuppyButtonClick">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="ButtonChrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="ButtonChrome"
                                    Property="Background"
                                    Value="#F0363041" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="ButtonChrome"
                                    Property="Background"
                                    Value="#F05B4A25" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Image x:Name="PuppyIconImage"
                   Source="Assets/Icons/puppy-icon.png"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Stretch="Uniform" />
        </Button>

        <Border x:Name="VoiceBusyIndicator"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Panel.ZIndex="3"
                Margin="0,4,0,0"
                Padding="8,3"
                Background="#E8201D2B"
                BorderBrush="#A8D9CCFF"
                BorderThickness="1"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="VoiceBusyText"
                           Foreground="#F7F1FF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="Thinking" />
                <TextBlock x:Name="VoiceBusyDots"
                           Width="16"
                           Foreground="#F7F1FF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Text="..." />
            </StackPanel>
        </Border>

        <Image x:Name="SpriteImage"
               Width="160"
               Height="144"
               Panel.ZIndex="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               RenderOptions.BitmapScalingMode="HighQuality"
               RenderTransformOrigin="0.5,0.5"
               Stretch="Uniform" />
    </Grid>
</Window>
